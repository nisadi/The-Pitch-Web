# Supabase project: obgaqcmxhrmslgjaerel
# Dashboard: https://supabase.com/dashboard/project/obgaqcmxhrmslgjaerel

# --- Supabase API (required for auth + Data API) ---
# Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://obgaqcmxhrmslgjaerel.supabase.co

# Project Settings → API → anon key (legacy) OR publishable key (new)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Optional alias for new key format
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only — never expose to the browser
# Project Settings → API → service_role (legacy) OR secret key (new)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-or-secret-key

# --- Postgres (optional; for raw SQL via src/lib/db/sql.js) ---
# Use Session pooler on IPv4 networks (Dashboard → Database → Connect → Session pooler):
# DATABASE_URL=postgresql://postgres.obgaqcmxhrmslgjaerel:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres

# Direct connection (IPv6; may not work on all networks):
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.obgaqcmxhrmslgjaerel.supabase.co:5432/postgres

# --- EmailJS (invite emails, sent from browser) ---
# Email Services → Service ID (service_xxx)
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
# Email Templates → Template ID (template_xxx)
NEXT_PUBLIC_EMAILJS_INVITE_TEMPLATE_ID=
# Account → API keys → Public Key
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=

# Optional. Used to generate the login link in invite emails.
# If unset, the app will use window.location.origin.
NEXT_PUBLIC_SITE_URL=

# --- Dialog eSMS (server-only; enquiry admin SMS replies) ---
# Used by messenger.js via /api/admin/enquiries/send-sms
ESMS_USERNAME=
ESMS_PASSWORD=
# Sender mask (max 11 chars), e.g. Dentax
ESMS_DEFAULT_MASK=
# Optional GET API key (if ESMS_USE_GET=true)
ESMS_GET_KEY=
# Set to true to use GET instead of POST (default POST)
# ESMS_USE_GET=false

# Shown at the end of enquiry reply SMS (footer contact line)
PITCH_CONTACT_PHONE=+94 11 456 7890
